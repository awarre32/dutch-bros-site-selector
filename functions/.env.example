# Copy this file to .env and fill in your keys.
# The .env file is gitignored and never deployed.
# For PRODUCTION (deployed Cloud Functions), set these in Google Cloud Console:
#   Cloud Functions > your function > Edit > Environment variables

# ── AI Extraction (at least one required) ──────────────────────────
# Gemini is preferred if both are set.
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Scraping: Serper.dev (recommended, primary discovery) ──────────
# Google Search API — finds individual listing pages across all CRE platforms.
# Free: 2,500 queries/month. Get key at https://serper.dev
SERPER_API_KEY=

# ── Scraping: Google Custom Search (optional, supplementary) ──────
# Create a Programmable Search Engine at programmablesearchengine.google.com
# restricted to: loopnet.com, crexi.com, commercialsearch.com,
# commercialcafe.com, ten-x.com, landwatch.com, land.com,
# totalcommercial.com, coldwellbankercommercial.com, cushmanwakefield.com
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ── Scraping: Firecrawl (recommended) ─────────────────────────────
# Get a free API key at https://firecrawl.dev
# Renders JS-heavy pages (LoopNet, Crexi, etc.) into clean markdown.
FIRECRAWL_API_KEY=

# ── Google Geocoding (recommended) ─────────────────────────────────
# Geocodes qualifying site addresses to lat/lng for map display.
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_GEOCODING_API_KEY=

# ── Manual Scrape Auth (optional) ──────────────────────────────────
# If set, POST /runScrapeNow requires ?key=YOUR_SECRET or body.key
SCRAPE_SECRET=
